{
  "message": {
    "prefix": "msg",
    "body": [
      "message ${1:Name} {",
      "  $0",
      "}"
    ],
    "description": "Define a new message"
  },
  "message-with-field": {
    "prefix": "msgf",
    "body": [
      "message ${1:Name} {",
      "  ${2:string} ${3:field_name} = ${4:1};",
      "  $0",
      "}"
    ],
    "description": "Define a new message with a field"
  },
  "enum": {
    "prefix": "enum",
    "body": [
      "enum ${1:Name} {",
      "  ${2:UNKNOWN} = 0;",
      "  $0",
      "}"
    ],
    "description": "Define a new enum"
  },
  "service": {
    "prefix": "svc",
    "body": [
      "service ${1:Name} {",
      "  rpc ${2:Method}(${3:Request}) returns (${4:Response}) {}",
      "  $0",
      "}"
    ],
    "description": "Define a new service"
  },
  "rpc": {
    "prefix": "rpc",
    "body": [
      "rpc ${1:Method}(${2:Request}) returns (${3:Response}) {}"
    ],
    "description": "Define an RPC method"
  },
  "rpc-stream-request": {
    "prefix": "rpcs",
    "body": [
      "rpc ${1:Method}(stream ${2:Request}) returns (${3:Response}) {}"
    ],
    "description": "Define an RPC method with streaming request"
  },
  "rpc-stream-response": {
    "prefix": "rpcsr",
    "body": [
      "rpc ${1:Method}(${2:Request}) returns (stream ${3:Response}) {}"
    ],
    "description": "Define an RPC method with streaming response"
  },
  "rpc-bidirectional": {
    "prefix": "rpcb",
    "body": [
      "rpc ${1:Method}(stream ${2:Request}) returns (stream ${3:Response}) {}"
    ],
    "description": "Define a bidirectional streaming RPC method"
  },
  "field-string": {
    "prefix": "fstr",
    "body": [
      "string ${1:name} = ${2:1};"
    ],
    "description": "String field"
  },
  "field-int32": {
    "prefix": "fint",
    "body": [
      "int32 ${1:name} = ${2:1};"
    ],
    "description": "Int32 field"
  },
  "field-int64": {
    "prefix": "fint64",
    "body": [
      "int64 ${1:name} = ${2:1};"
    ],
    "description": "Int64 field"
  },
  "field-bool": {
    "prefix": "fbool",
    "body": [
      "bool ${1:name} = ${2:1};"
    ],
    "description": "Bool field"
  },
  "field-bytes": {
    "prefix": "fbytes",
    "body": [
      "bytes ${1:name} = ${2:1};"
    ],
    "description": "Bytes field"
  },
  "field-repeated": {
    "prefix": "frep",
    "body": [
      "repeated ${1:type} ${2:name} = ${3:1};"
    ],
    "description": "Repeated field"
  },
  "field-map": {
    "prefix": "fmap",
    "body": [
      "map<${1:key_type}, ${2:value_type}> ${3:name} = ${4:1};"
    ],
    "description": "Map field"
  },
  "oneof": {
    "prefix": "oneof",
    "body": [
      "oneof ${1:name} {",
      "  ${2:type} ${3:field} = ${4:1};",
      "  $0",
      "}"
    ],
    "description": "Oneof field group"
  },
  "import": {
    "prefix": "imp",
    "body": [
      "import \"${1:path/to/file.proto}\";"
    ],
    "description": "Import statement"
  },
  "import-public": {
    "prefix": "impp",
    "body": [
      "import public \"${1:path/to/file.proto}\";"
    ],
    "description": "Public import statement"
  },
  "option-go-package": {
    "prefix": "optgo",
    "body": [
      "option go_package = \"${1:package/path}\";"
    ],
    "description": "Go package option"
  },
  "proto3": {
    "prefix": "proto3",
    "body": [
      "syntax = \"proto3\";",
      "",
      "package ${1:package_name};",
      "",
      "option go_package = \"${2:package/path}\";",
      "",
      "$0"
    ],
    "description": "Proto3 file boilerplate"
  },
  "proto3-full": {
    "prefix": "proto3f",
    "body": [
      "syntax = \"proto3\";",
      "",
      "package ${1:package_name};",
      "",
      "option go_package = \"${2:package/path}\";",
      "",
      "message ${3:Request} {",
      "  $0",
      "}",
      "",
      "message ${3:Request}Response {",
      "  ",
      "}",
      "",
      "service ${4:Service} {",
      "  rpc ${5:Method}($3) returns (${3}Response) {}",
      "}"
    ],
    "description": "Full proto3 file with message and service"
  },
  "buffalo-validate-required": {
    "prefix": "bvreq",
    "body": [
      "[(buffalo.validate.rules).${1:string} = { required: true }]"
    ],
    "description": "Buffalo validation: required field"
  },
  "buffalo-validate-min-max": {
    "prefix": "bvminmax",
    "body": [
      "[(buffalo.validate.rules).${1:string} = { min_len: ${2:1}, max_len: ${3:255} }]"
    ],
    "description": "Buffalo validation: min/max length"
  },
  "buffalo-validate-email": {
    "prefix": "bvemail",
    "body": [
      "[(buffalo.validate.rules).string = { email: true }]"
    ],
    "description": "Buffalo validation: email format"
  },
  "buffalo-validate-uuid": {
    "prefix": "bvuuid",
    "body": [
      "[(buffalo.validate.rules).string = { uuid: true }]"
    ],
    "description": "Buffalo validation: UUID format"
  },
  "buffalo-validate-regex": {
    "prefix": "bvregex",
    "body": [
      "[(buffalo.validate.rules).string = { pattern: \"${1:^[a-z]+$}\" }]"
    ],
    "description": "Buffalo validation: regex pattern"
  },
  "buffalo-permissions-public": {
    "prefix": "bppub",
    "body": [
      "option (buffalo.permissions.public) = true;"
    ],
    "description": "Buffalo permissions: public access"
  },
  "buffalo-permissions-resource": {
    "prefix": "bpres",
    "body": [
      "option (buffalo.permissions.resource) = \"${1:resource_name}\";"
    ],
    "description": "Buffalo permissions: resource name"
  },
  "buffalo-permissions-action": {
    "prefix": "bpact",
    "body": [
      "option (buffalo.permissions.action) = \"${1:read|write|delete|admin}\";"
    ],
    "description": "Buffalo permissions: action"
  },
  "buffalo-permissions-roles": {
    "prefix": "bproles",
    "body": [
      "option (buffalo.permissions.roles) = [\"${1:admin}\", \"${2:user}\"];"
    ],
    "description": "Buffalo permissions: allowed roles"
  }
}
